# pyenv
#   For a library or app, you might want to commit this.
#   Uncomment if you want to ignore the local python version file.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing pipelines inside virtualenvs, you may not want to share those.
#Pipfile.lock

# poetry
#   Using Poetry, it's common to commit poetry.lock and pyproject.toml
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, it's highly recommended to commit pdm.lock into version control
#pdm.lock
#   pdm build pack target
.pdm-plugins/

# PEP 582; project packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

